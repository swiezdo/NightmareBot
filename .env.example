# Discord (required)
DISCORD_TOKEN=
CLIENT_ID=
# In the Developer Portal enable Message Content Intent (bulk wave paste in DMs).

# Comma-separated or JSON array: 123456789,987654321 or ["123456789"]
# Managers: /whitelist-add|remove|show + always /setup-waves, /edit-waves, bulk DM.
# Others get access via /whitelist-add (stored in DB). /waves is public.
ALLOWED_USER_IDS=

# 1 — verbose WebSocket debug log (optional)
# WAVES_BOT_DEBUG=1

# Nightmare.Club Tsushima: token required for GET + PUT.
# Same secret as BOT_API_TOKEN_TSUSHIMA in the Nightmare.Club deployment
NIGHTMARE_CLUB_TSUSHIMA_TOKEN=
# PUT URL (optional if read URL ends with /api/rotation/tsushima): default is derived from
# NIGHTMARE_CLUB_TSUSHIMA_READ_URL or from nightmare.club when neither URL is set.
# Full path: https://your-domain.com/api/rotations/tsushima
# NIGHTMARE_CLUB_TSUSHIMA_URL=
# Optional: GET for /waves & edit-waves (default: from TSUSHIMA_URL …/rotations/→…/rotation/, else nightmare.club)
# NIGHTMARE_CLUB_TSUSHIMA_READ_URL=

# Nightmare.Club Yōtei read (required for /waves game=Yōtei): GET with Bearer
# Same secret as BOT_API_TOKEN_YOTEI on the site. PUT URL optional if you only read:
# NIGHTMARE_CLUB_YOTEI_URL=https://your-domain.com/api/rotations/yotei
NIGHTMARE_CLUB_YOTEI_TOKEN=
# NIGHTMARE_CLUB_YOTEI_READ_URL=https://your-domain.com/api/rotation/yotei

# SQLite DB path is fixed: data/waves_bot.db (sessions). sqlite-web uses the same file; see README + deploy/.
