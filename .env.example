# Discord (required)
DISCORD_TOKEN=
CLIENT_ID=
# In the Developer Portal enable Message Content Intent (bulk wave paste in DMs).

# Comma-separated or JSON array: 123456789,987654321 or ["123456789"]
SETUP_WAVES_ALLOWED_USER_IDS=

# 1 — verbose WebSocket debug log (optional)
# WAVES_BOT_DEBUG=1

# SQLite DB path is fixed: data/waves_bot.db (sessions). sqlite-web uses the same file; see README + deploy/.
